SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgres://user:password@localhost:5432/ata_workflow
ALLOWED_HOSTS=localhost,127.0.0.1

# Email (development uses console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ata.com

# Finance & Ops notification targets
FINANCE_EMAIL=finance@ata.com
OPS_EMAIL=ops@ata.com
SLACK_OPS_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
